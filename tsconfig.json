{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  // scripts/** are standalone Node/CLI tools (data audits and one-off DB
  // fixes), never imported by the deployed app, run directly via `tsx`
  // (which transpiles per-file with esbuild and doesn't care about this
  // project's `target`/`lib`, so excluding them here has no effect on
  // actually running them — `npm run fix:...` etc. keep working unchanged).
  // They were swept into `next build`'s whole-project type-check by the
  // broad "**/*.ts" include above, which failed two deploys in a row on
  // scripts that pre-date any of this — e.g. Map/Set for-of iteration
  // needing --downlevelIteration under this project's target. Excluding the
  // whole directory prevents every future standalone script from being able
  // to break the production build the same way, not just this one file.
  "exclude": ["node_modules", "scripts"]
}
