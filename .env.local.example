# ─────────────────────────────────────────────────────────────────────────
# Supabase (Project Settings > API in the Supabase dashboard)
# ─────────────────────────────────────────────────────────────────────────

# Project URL, e.g. https://xxxxxxxxxxxx.supabase.co — safe to expose to the
# browser (used by the client-side Supabase Auth SDK).
NEXT_PUBLIC_SUPABASE_URL=

# Project "anon" / "public" API key — safe to expose to the browser. RLS is
# enabled with no policies for anon/authenticated on every table, so this
# key alone cannot read or write application data (see CLAUDE.md "Database
# Schema" > Access model); it's only used to establish the auth session.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role API key — SERVER-ONLY, never expose to the client or commit
# it. Bypasses Row Level Security. Every API route uses this (via
# lib/supabase/admin.ts) to read/write requests, roles, categories, etc.
# All application-layer permission checks live in lib/permissions.ts, since
# RLS itself grants nothing.
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────────────────

# Base URL of this deployment, e.g. https://expenses.mimetta.co in
# production. Not currently read by any code path (OAuth redirects are
# built client-side from window.location.origin instead — see
# app/login/page.tsx) but reserved/documented for building absolute URLs
# server-side (emails, Discord message links, etc.) if that's ever needed.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────
# Discord notifications (lib/discord.ts, lib/constants.ts)
# One webhook per department's Discord channel, plus CEO and a fallback for
# departments with no dedicated channel (Factory Investment, People & HR &
# System, Merchandise, COG). Create each as a Discord channel's
# Integrations > Webhooks > New Webhook, copy the URL. Any of these can be
# left blank in a non-production environment — lib/discord.ts silently
# no-ops a notification if its webhook URL isn't configured.
# ─────────────────────────────────────────────────────────────────────────

DISCORD_WEBHOOK_FACTORY=
DISCORD_WEBHOOK_MARKETING=
DISCORD_WEBHOOK_RD=
DISCORD_WEBHOOK_STOREINV=
DISCORD_WEBHOOK_WH=
DISCORD_WEBHOOK_RETAIL=
DISCORD_WEBHOOK_GA=
DISCORD_WEBHOOK_FACINV=
DISCORD_WEBHOOK_LABINV=
DISCORD_WEBHOOK_CEO=

# Fallback used for departments with no dedicated channel above, then
# DISCORD_WEBHOOK_GA if even that's unset.
DISCORD_WEBHOOK_DEFAULT=

# ─────────────────────────────────────────────────────────────────────────
# Vercel Cron
# ─────────────────────────────────────────────────────────────────────────

# Bearer token required by GET /api/cron/document-reminder (see vercel.json
# for the schedule). Set the same value here and in the Vercel project's
# environment variables — Vercel Cron sends it as
# `Authorization: Bearer <CRON_SECRET>` on its invocation. Any long random
# string; generate one with e.g. `openssl rand -hex 32`.
CRON_SECRET=

# ─────────────────────────────────────────────────────────────────────────
# Google Drive attachment upload (lib/google-drive.ts,
# app/api/upload-to-drive/route.ts) — /submit and every edit form upload
# attachments straight into the requester's own Drive, using their Google
# OAuth access token (Supabase's `session.provider_token`), not a service
# account. Set the same value here and in the Vercel project's environment
# variables.
# ─────────────────────────────────────────────────────────────────────────

# Drive folder id ("Expense Portal") that every request's files are filed
# under, as .../<budgetPeriod>/<request_id>/. Marked NEXT_PUBLIC_ only
# because it was specified that way — it's actually only ever read
# server-side (app/api/upload-to-drive/route.ts), never in browser code.
# Must be a folder every @mimetta.co user's Google account can already
# write to for this to work — see the header comment in
# app/api/upload-to-drive/route.ts for the drive.file-scope caveat this
# implies.
NEXT_PUBLIC_GOOGLE_DRIVE_FOLDER_ID=1r0FFSMf_whiXK6PL3JGXiRSyN_84E_4x
